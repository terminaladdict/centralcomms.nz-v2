---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  noindex?: boolean;
  ogType?: string;
  articleDate?: string;
  canonicalURL?: string;
}

const {
  title,
  description = "Central Communications Ltd provides smart solutions for VoIP, CCTV, data cabling, WiFi, UFB and web hosting throughout the Waikato and beyond.",
  image,
  imageWidth,
  imageHeight,
  noindex = false,
  ogType = "website",
  articleDate,
  canonicalURL,
} = Astro.props;

const defaultOgImage = "/assets/images/ccl-og-image.png";
const ogImage = image ?? defaultOgImage;
const ogImageWidth  = imageWidth  ?? (image ? undefined : 1200);
const ogImageHeight = imageHeight ?? (image ? undefined : 630);

const canonical = canonicalURL
  ? new URL(canonicalURL, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === "Home"
  ? "Central Communications Ltd — Building Better Business Infrastructure"
  : /Central (Communications|Comms)/i.test(title)
  ? title
  : `${title} | Central Communications Ltd`;

const siteUrl = new URL("/", Astro.site);
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": new URL("#business", siteUrl).href,
  "name": "Central Communications Ltd",
  "legalName": "Central Communications Ltd",
  "url": siteUrl.href,
  "image": new URL(defaultOgImage, Astro.site).href,
  "logo": new URL("/assets/images/centralcomms.svg", Astro.site).href,
  "telephone": "+648008480038",
  "priceRange": "$$",
  "description": "Smart telecommunications, security, networking, wireless, UFB and web hosting solutions for businesses throughout the Waikato and beyond.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 3/103C Greenwood Street, Frankton",
    "addressLocality": "Hamilton",
    "postalCode": "3204",
    "addressCountry": "NZ"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -37.7870,
    "longitude": 175.2793
  },
  "areaServed": ["Hamilton", "Waikato", "Bay of Plenty", "South Auckland"],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:30",
      "closes": "17:00"
    }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Telecommunications, Security and IT Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "url": new URL("/voip.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "Business VoIP Phone Systems",
          "serviceType": "VoIP phone systems"
        }
      },
      {
        "@type": "Offer",
        "url": new URL("/cctv.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "CCTV and Security Surveillance",
          "serviceType": "Security camera installation"
        }
      },
      {
        "@type": "Offer",
        "url": new URL("/networking--data.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "Structured Data Cabling and Networking",
          "serviceType": "Network cabling"
        }
      },
      {
        "@type": "Offer",
        "url": new URL("/it-support.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "Business IT Support and Hardware Sales",
          "serviceType": "IT support"
        }
      },
      {
        "@type": "Offer",
        "url": new URL("/wireless.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "Enterprise WiFi and Wireless Links",
          "serviceType": "Wireless networking"
        }
      },
      {
        "@type": "Offer",
        "url": new URL("/ultra-fast-broadband.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "Business Ultra Fast Broadband",
          "serviceType": "Business broadband"
        }
      },
      {
        "@type": "Offer",
        "url": new URL("/websites-and-hosting.html", Astro.site).href,
        "itemOffered": {
          "@type": "Service",
          "name": "Websites and Managed Hosting",
          "serviceType": "Web hosting"
        }
      }
    ]
  }
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{fullTitle}</title>
  <meta name="title" content={fullTitle} />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  {ogImageWidth  && <meta property="og:image:width"  content={String(ogImageWidth)}  />}
  {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
  <meta property="og:image:alt" content={fullTitle} />
  <meta property="og:site_name" content="Central Communications Ltd" />
  <meta property="og:locale" content="en_NZ" />
  <meta property="fb:app_id" content="3290029181181689" />
{ogType === "article" && articleDate && (
    <meta property="article:published_time" content={new Date(articleDate + "T00:00:00").toISOString()} />
  )}
  {ogType === "article" && (
    <meta property="article:author" content="Central Communications Ltd" />
  )}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonical} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&family=Space+Mono&display=swap"
  />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- Reveal on scroll -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
  <script async src="/assets/console.js"></script>
  <script src="https://app.slack-web-chat.com/widget/widget.min.js?key=976e50aa6dbf06ab735d2af54b21f2ec8eb8c3abaa518a51" async defer></script>
</body>
</html>
