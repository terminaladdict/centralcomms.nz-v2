---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Fair Use Policy — Central Communications Ltd" description="Fair use policy for Central Communications Ltd internet and telecommunications services." noindex={true}>
  <div class="page-hero">
    <div class="container">
      <span class="section-tag">Legal</span>
      <h1 class="page-title">Fair Use <em>Policy</em></h1>
      <p class="page-sub">Central Communications Limited</p>
    </div>
  </div>
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="prose">
        <h2>Fair Use Policy</h2>
        <p>Central Communications Ltd provides internet and telecommunications services to businesses and individuals throughout New Zealand. Our Fair Use Policy ensures that all customers receive a fair and consistent quality of service.</p>
        <h2>Acceptable Use</h2>
        <p>Our services are provided for legitimate personal and business purposes. You agree not to use our services for any unlawful purposes, including but not limited to spam, hacking, or distribution of malicious software.</p>
        <h2>Network Management</h2>
        <p>Central Communications reserves the right to apply traffic management measures during periods of network congestion to ensure all customers receive a fair level of service. We will notify customers of any significant changes to our traffic management policies.</p>
        <h2>Contact</h2>
        <p>If you have any questions about this fair use policy, please <a href="/support.html#contact">contact us</a> or call <a href="tel:+6480084800038">0800 848 0038</a>.</p>
      </div>
    </div>
  </section>
</Layout>
<style>
  .page-title { font-size: clamp(2rem, 5vw, 3.5rem); color: #e8f1ff; margin: 0.5rem 0 1rem; }
  .page-title em { font-style: normal; color: #0ea5e9; }
  .page-sub { font-size: 1.1rem; color: #7ea3c8; }
</style>
