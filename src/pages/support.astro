---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Technical Support — Central Communications Ltd"
  description="After-sales support for all Central Communications services. Remote support via HelpWire, 24/7 emergency line, and our support request form."
>
  <div class="page-hero">
    <div class="container">
      <span class="section-tag">Support</span>
      <h1 class="page-title">Technical &amp;<br /><em>Product Support</em></h1>
      <p class="page-sub">We're here when you need us — 24/7 for emergencies, next business day for everything else.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="support-grid">

        <!-- Left: info -->
        <div>
          <h2 class="content-h2 reveal">After-Sales Support</h2>
          <p class="body-text reveal reveal-delay-1">
            After the purchase and installation of your technology, Central Communications' service
            doesn't end there. Our technicians are there to answer questions, make changes to settings,
            and ensure you get the full potential out of your equipment.
          </p>
          <p class="body-text reveal reveal-delay-2">
            The vast majority of support can be done remotely, saving you money with no need for our
            technicians to attend site. We offer <strong style="color:#27448f;">24/7 emergency service</strong> and next-day
            response via email, phone or remote access for non-urgent enquiries.
          </p>

          <!-- HelpWire -->
          <div class="helpwire-box reveal reveal-delay-3">
            <svg class="helpwire-icon" viewBox="0 0 48 48" width="48" height="48" fill="none" aria-hidden="true">
              <rect width="48" height="48" rx="12" fill="#0ea5e9"/>
              <path d="M14 24a10 10 0 1 1 20 0 10 10 0 0 1-20 0Z" fill="white" fill-opacity="0.15"/>
              <path d="M24 16v8l5 3" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 34c2-4 7-7 14-7s12 3 14 7" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <div>
              <h3 class="helpwire-title">Remote Support via HelpWire</h3>
              <p class="body-text" style="margin:0 0 0.75rem;">
                We use HelpWire to connect directly to your computer and resolve issues fast — no technical
                knowledge required on your end. It's free, simple, and secure. When you call us for remote
                support, we'll send you everything you need to get connected.
              </p>
              <div class="helpwire-steps">
                <div class="step">
                  <span class="step-num">1</span>
                  <span>Call us on <a href="tel:+6480084800038" class="inline-link">0800 848 0038</a> to start a remote session</span>
                </div>
                <div class="step">
                  <span class="step-num">2</span>
                  <span>Download and run the HelpWire app that we send you.</span>
                </div>
                <div class="step">
                  <span class="step-num">3</span>
                  <span>We'll take it from there.</span>
                </div>
              </div>
            </div>
          </div>

          <div class="helpwire-note reveal reveal-delay-4">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            HelpWire is free for customers to use and requires no installation — just download, run, and share your ID with our technician. The session ends the moment you close the app.
          </div>
        </div>

        <!-- Right: contact form -->
        <div id="contact" class="reveal reveal-delay-2">
          <div class="contact-card">
            <h2 class="content-h2" style="margin-top:0;">Send a Support Request</h2>
            <form id="support-form" method="post" action="/assets/php/contact.php" novalidate>
              <div class="form-field">
                <label for="s-name">Name *</label>
                <input type="text" id="s-name" name="name" required autocomplete="name" placeholder="Your name" />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-field">
                <label for="s-email">Email *</label>
                <input type="email" id="s-email" name="email" required autocomplete="email" placeholder="you@company.co.nz" />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-field">
                <label for="s-phone">Phone</label>
                <input type="tel" id="s-phone" name="phone" autocomplete="tel" placeholder="027 000 0000" />
              </div>
              <div class="form-field">
                <label for="s-issue">Issue *</label>
                <textarea id="s-issue" name="message" required placeholder="Describe the problem you're experiencing…"></textarea>
              </div>
              <div id="support-status" aria-live="polite"></div>
              <button type="submit" class="btn btn-ember" style="width:100%;justify-content:center;">
                Send Support Request
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
<script>
  const form = document.getElementById('support-form') as HTMLFormElement;
  const status = document.getElementById('support-status')!;
  const btn = form?.querySelector('[type="submit"]') as HTMLButtonElement;

  function validateForm(): boolean {
    let valid = true;
    form.querySelectorAll('.field-error').forEach(el => (el.textContent = ''));
    form.querySelectorAll('.form-field').forEach(el => el.classList.remove('has-error'));

    const nameEl  = form.querySelector('[name="name"]')  as HTMLInputElement;
    const emailEl = form.querySelector('[name="email"]') as HTMLInputElement;

    if (nameEl.value.trim().length < 2) {
      nameEl.closest('.form-field')!.classList.add('has-error');
      nameEl.closest('.form-field')!.querySelector('.field-error')!.textContent = 'Please enter your name (at least 2 characters).';
      valid = false;
    }

    const emailVal = emailEl.value.trim();
    if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      emailEl.closest('.form-field')!.classList.add('has-error');
      emailEl.closest('.form-field')!.querySelector('.field-error')!.textContent = 'Please enter a valid email address.';
      valid = false;
    }

    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateForm()) return;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.className = '';
    status.textContent = '';
    try {
      const token = await new Promise<string>(resolve => {
        (window as any).grecaptcha.ready(() => {
          (window as any).grecaptcha.execute('6LdRnncaAAAAAEFm9NdFYNZ4v7HooLGMqw0jdEiV', { action: 'contact' }).then(resolve);
        });
      });
      const data = new FormData(form);
      data.append('token', token);
      data.append('action', 'contact');
      const res  = await fetch('/assets/php/contact.php', { method: 'POST', body: data });
      const json = await res.json();
      if (json.success) {
        status.className = 'success';
        status.textContent = json.message || 'Request sent! We\'ll be in touch soon.';
        form.reset();
      } else { throw new Error(json.message); }
    } catch (err: any) {
      status.className = 'error';
      status.textContent = err.message || 'Something went wrong. Please call 0800 848 0038.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Support Request';
    }
  });
</script>

<script src="https://www.google.com/recaptcha/api.js?render=6LdRnncaAAAAAEFm9NdFYNZ4v7HooLGMqw0jdEiV" async defer></script>

</Layout>

<style>
  .page-title { font-size: clamp(2rem, 5vw, 3.5rem); color: #e8f1ff; margin: 0.5rem 0 1rem; }
  .page-title em { font-style: normal; color: #0ea5e9; }
  .page-sub { font-size: 1.1rem; color: #7ea3c8; max-width: 520px; }

  .support-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: start;
  }

  .content-h2 {
    font-size: 1.6rem;
    color: #27448f;
    margin: 0 0 1rem;
  }

  .body-text {
    color: #334e68;
    line-height: 1.8;
    font-size: 0.975rem;
    margin-bottom: 1rem;
  }

  .helpwire-box {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: #f0f9ff;
    border: 1px solid rgba(14, 165, 233, 0.2);
    border-radius: 1rem;
    padding: 1.5rem;
    margin: 1.5rem 0 1rem;
  }
  .helpwire-icon { flex-shrink: 0; margin-top: 0.25rem; }
  .helpwire-title {
    font-family: "Syne", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 0.5rem;
  }

  .helpwire-steps {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.75rem;
  }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: #334e68;
    line-height: 1.5;
  }
  .step-num {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    background: #0ea5e9;
    color: #fff;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.05rem;
  }
  .inline-link { color: #0369a1; text-decoration: underline; }

  .helpwire-note {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    font-size: 0.83rem;
    color: #486581;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .helpwire-note svg { flex-shrink: 0; margin-top: 0.15rem; color: #64748b; }

  .contact-card {
    background: #0c1d35;
    border: 1px solid rgba(14, 165, 233, 0.15);
    border-radius: 1.25rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }
  .contact-card .content-h2 { color: #e8f1ff; }
  .contact-card form { display: flex; flex-direction: column; gap: 1rem; }

  #support-status { font-size: 0.875rem; min-height: 1.5rem; }
  #support-status.success { color: #4ade80; }
  #support-status.error   { color: #f87171; }

  .field-error { display: block; font-size: 0.78rem; color: #f87171; margin-top: 0.2rem; min-height: 1em; }
  .form-field.has-error input,
  .form-field.has-error textarea { border-color: #ef4444; outline: none; }

  @media (max-width: 900px) {
    .support-grid { grid-template-columns: 1fr; }
    .contact-card { position: static; }
  }
</style>

