---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Service Notifications — Central Communications Ltd"
  description="Current service status and network outage notifications for Central Communications Ltd customers."
  noindex={false}
>
  <div class="page-hero">
    <div class="container">
      <span class="section-tag">Support — Notifications</span>
      <h1 class="page-title">Service<br /><em>Notifications</em></h1>
      <p class="page-sub">Current status of Central Communications services and any known outages.</p>
    </div>
  </div>

  <section class="section">
    <div class="container" style="max-width:820px;">

      <div class="status-banner reveal">
        <div class="status-dot green"></div>
        <div>
          <div class="status-title">All Systems Operational</div>
          <div class="status-time" id="status-time">Last checked now</div>
        </div>
      </div>

      <div class="notifications-intro reveal reveal-delay-1">
        <p>
          This page lists any known outages or service disruptions affecting Central Communications
          customers. If you're experiencing an issue not listed here, please contact us directly.
        </p>
        <div class="contact-row">
          <a href="tel:+6480084800038" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.59 4.87 2 2 0 0 1 3.56 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.16a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            0800 848 0038
          </a>
          <a href="/support.html#contact" class="btn btn-outline">Send a message</a>
        </div>
      </div>

      <div class="notifications-empty reveal reveal-delay-2">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:#0ea5e9;opacity:0.4;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <p>No active notifications — everything is running smoothly.</p>
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-title { font-size: clamp(2rem, 5vw, 3.5rem); color: #e8f1ff; margin: 0.5rem 0 1rem; }
  .page-title em { font-style: normal; color: #0ea5e9; }
  .page-sub { font-size: 1.1rem; color: #7ea3c8; max-width: 520px; }

  .status-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(74, 222, 128, 0.06);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }
  .status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-dot.green {
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .status-title { font-family: "Syne", sans-serif; font-weight: 700; color: #4ade80; font-size: 1rem; }
  .status-time { font-size: 0.8rem; color: #7ea3c8; margin-top: 0.2rem; }

  .notifications-intro {
    color: #7ea3c8;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .notifications-intro p { margin-bottom: 1.25rem; }

  .contact-row { display: flex; gap: 1rem; flex-wrap: wrap; }

  .notifications-empty {
    text-align: center;
    padding: 4rem 2rem;
    border: 1px dashed rgba(14, 165, 233, 0.15);
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .notifications-empty p { color: #7ea3c8; font-size: 0.95rem; margin: 0; }
</style>

<script>
  const el = document.getElementById('status-time');
  if (el) {
    const now = new Date();
    el.textContent = `Last checked: ${now.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })} at ${now.toLocaleTimeString('en-NZ', { hour: '2-digit', minute: '2-digit' })}`;
  }
</script>
