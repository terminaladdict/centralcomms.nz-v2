---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Service Notifications — Central Communications Ltd"
  description="Current service status and network outage notifications for Central Communications Ltd customers."
  noindex={false}
>
  <div class="page-hero">
    <div class="container">
      <span class="section-tag">Support — Notifications</span>
      <h1 class="page-title">Service<br /><em>Notifications</em></h1>
      <p class="page-sub">Current status of Central Communications services and any known outages.</p>
    </div>
  </div>

  <section class="section">
    <div class="container notif-container">

      <!-- Status banner -->
      <div class="status-banner" id="status-banner">

        <!-- Loader shown while API call is in flight -->
        <div id="status-loader" class="status-loader">
          <svg class="status-loader-char" viewBox="0 0 80 92" width="52" height="60" aria-hidden="true">
            <!-- Hair tufts -->
            <circle cx="31" cy="13" r="5" fill="#14532d"/>
            <circle cx="40" cy="10" r="5" fill="#14532d"/>
            <circle cx="49" cy="13" r="5" fill="#14532d"/>
            <!-- Head -->
            <circle cx="40" cy="28" r="17" fill="#166534"/>
            <!-- Binoculars body -->
            <rect x="11" y="20" width="22" height="15" rx="5" fill="#15803d"/>
            <rect x="47" y="20" width="22" height="15" rx="5" fill="#15803d"/>
            <!-- Bridge -->
            <rect x="33" y="24" width="14" height="7" rx="3" fill="#16a34a"/>
            <!-- Lenses (dark glass) -->
            <circle cx="22" cy="27" r="7.5" fill="#052e16"/>
            <circle cx="58" cy="27" r="7.5" fill="#052e16"/>
            <!-- Lens glare -->
            <circle cx="19" cy="24" r="2.5" fill="rgba(134,239,172,0.65)"/>
            <circle cx="55" cy="24" r="2.5" fill="rgba(134,239,172,0.65)"/>
            <!-- Tiny hands gripping binoculars -->
            <circle cx="10" cy="27" r="5" fill="#14532d"/>
            <circle cx="70" cy="27" r="5" fill="#14532d"/>
            <!-- Smile (below binoculars) -->
            <path d="M32 41 Q40 47 48 41" stroke="#4ade80" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <!-- Body -->
            <rect x="22" y="45" width="36" height="26" rx="11" fill="#166534"/>
            <!-- Legs -->
            <rect x="25" y="68" width="11" height="14" rx="5.5" fill="#166534"/>
            <rect x="44" y="68" width="11" height="14" rx="5.5" fill="#166534"/>
            <!-- Feet -->
            <ellipse cx="30.5" cy="82" rx="9.5" ry="5" fill="#15803d"/>
            <ellipse cx="49.5" cy="82" rx="9.5" ry="5" fill="#15803d"/>
          </svg>
          <div>
            <div class="status-loader-text">Scanning the network…</div>
          </div>
        </div>

        <!-- Real status content (hidden until loaded) -->
        <div id="status-real" class="status-real" style="display:none;">
          <div class="status-dot" id="status-dot"></div>
          <div>
            <div class="status-title" id="status-title"></div>
            <div class="status-time" id="status-time"></div>
          </div>
        </div>

      </div>

      <!-- Intro -->
      <div class="notifications-intro reveal reveal-delay-1">
        <p>
          This page lists any known outages or service disruptions affecting Central Communications
          customers. If you're experiencing an issue not listed here, please contact us directly.
        </p>
        <div class="contact-row">
          <a href="tel:+6480084800038" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.59 4.87 2 2 0 0 1 3.56 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.16a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            0800 848 0038
          </a>
          <a href="/support.html#contact" class="btn btn-outline">Send a message</a>
        </div>
      </div>

      <!-- Staff bar (shown when logged in) -->
      <div id="staff-bar" class="staff-bar" hidden>
        <span id="staff-greeting" class="staff-greeting"></span>
        <div class="staff-actions">
          <button id="add-notif-btn" class="btn btn-primary btn-sm">+ New Notification</button>
          <button id="logout-btn" class="btn-ghost-sm">Log out</button>
        </div>
      </div>

      <!-- Add / Edit notification form -->
      <div id="notif-form-wrap" class="notif-form-wrap" hidden>
        <form id="notif-form" novalidate>
          <h2 id="notif-form-heading" class="form-heading">New Notification</h2>
          <input type="hidden" id="notif-id-input">
          <div class="form-row-split">
            <div class="form-group">
              <label for="notif-status-input">Status</label>
              <select id="notif-status-input">
                <option value="info">Info</option>
                <option value="warning">Warning</option>
                <option value="outage">Outage</option>
                <option value="resolved">Resolved</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="notif-title-input">Title</label>
            <input type="text" id="notif-title-input" placeholder="e.g. Scheduled maintenance – UFB services" required>
          </div>
          <div class="form-group">
            <label for="notif-body-input">Body</label>
            <textarea id="notif-body-input" rows="6" placeholder="Describe the issue, affected services, and any workarounds…" required></textarea>
          </div>
          <div id="notif-form-error" class="form-error" hidden></div>
          <div class="form-actions">
            <button type="submit" id="notif-save-btn" class="btn btn-primary">Save Notification</button>
            <button type="button" id="notif-cancel-btn" class="btn-ghost-sm">Cancel</button>
          </div>
        </form>
      </div>

      <!-- Staff login (discreet — above the list so infinite scroll doesn't bury it) -->
      <div class="staff-login-area" id="staff-login-area">
        <button id="login-toggle" class="login-toggle-link">Staff login</button>
      </div>

      <!-- Login panel -->
      <div id="login-panel" class="login-panel" hidden>
        <form id="login-form" method="post" novalidate>
          <h2 class="form-heading">Staff Login</h2>
          <div class="form-group">
            <label for="login-username">Username</label>
            <input type="text" id="login-username" autocomplete="username" required>
          </div>
          <div class="form-group">
            <label for="login-password">Password</label>
            <input type="password" id="login-password" autocomplete="current-password" required>
          </div>
          <div id="login-error" class="form-error" hidden></div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Login</button>
            <button type="button" id="login-cancel" class="btn-ghost-sm">Cancel</button>
          </div>
        </form>
      </div>

      <!-- Notifications list -->
      <div id="notifications-list"></div>

      <!-- Infinite scroll sentinel (loads more resolved notifications) -->
      <div id="load-more-sentinel"></div>

    </div>
  </section>
<script>
  const API = '/assets/php/notifications-api.php';
  const RESOLVED_PER_LOAD = 5;

  let notifications = [];
  let resolvedVisible = RESOLVED_PER_LOAD;
  let isLoggedIn = false;
  let currentUser = null;
  let csrfToken = '';
  let editingNotifId = null;

  // ── Utilities ───────────────────────────────────────────────────────────────

  function esc(str) {
    const d = document.createElement('div');
    d.textContent = str ?? '';
    return d.innerHTML;
  }

  function escLines(str) {
    return esc(str).replace(/\n/g, '<br>');
  }

  function fmt(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })
      + ' at '
      + d.toLocaleTimeString('en-NZ', { hour: '2-digit', minute: '2-digit' });
  }

  function wasEdited(created, updated) {
    return Math.abs(new Date(updated) - new Date(created)) > 5000;
  }

  async function apiCall(action, params = {}, body = null) {
    const url = new URL(API, location.origin);
    url.searchParams.set('action', action);
    for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
    const opts = { method: body ? 'POST' : 'GET', credentials: 'same-origin' };
    if (body) {
      opts.headers = { 'Content-Type': 'application/json' };
      if (action !== 'login' && csrfToken) opts.headers['X-CSRF-Token'] = csrfToken;
      opts.body = JSON.stringify(body);
    }
    const res = await fetch(url, opts);
    try {
      return await res.json();
    } catch {
      return { error: `Server error ${res.status}: response was not JSON` };
    }
  }

  // ── Init ────────────────────────────────────────────────────────────────────

  async function init() {
    try {
      const [me, data] = await Promise.all([apiCall('me'), apiCall('list')]);
      isLoggedIn = me.logged_in ?? false;
      currentUser = me.user ?? null;
      csrfToken = me.csrf ?? '';
      notifications = data.notifications ?? [];
    } catch (err) {
      console.error('Notifications API unavailable:', err);
      notifications = [];
    }
    render();
    updateStatusTime();
  }

  // ── Render ──────────────────────────────────────────────────────────────────

  function render() {
    renderStatusBanner();
    renderStaffBar();
    renderList();
    updateSentinel();
    // Hide login area when logged in
    const loginArea = document.getElementById('staff-login-area');
    if (loginArea) loginArea.hidden = isLoggedIn;
  }

  function renderStatusBanner() {
    const banner = document.getElementById('status-banner');
    const dot    = document.getElementById('status-dot');
    const title  = document.getElementById('status-title');
    if (!banner || !dot || !title) return;

    // Swap loader out for real content
    const loader = document.getElementById('status-loader');
    const real   = document.getElementById('status-real');
    if (loader) loader.style.display = 'none';
    if (real)   real.style.display   = 'flex';

    const active = notifications.filter(n => n.status !== 'resolved');
    const hasOutage  = active.some(n => n.status === 'outage');
    const hasWarning = active.some(n => n.status === 'warning' || n.status === 'info');

    banner.className = 'status-banner';
    dot.className    = 'status-dot';
    title.className  = 'status-title';

    if (hasOutage) {
      banner.classList.add('outage');
      dot.classList.add('outage');
      title.classList.add('outage');
      title.textContent = 'Service Disruption — See notifications below';
    } else if (hasWarning) {
      banner.classList.add('warning');
      dot.classList.add('warning');
      title.classList.add('warning');
      title.textContent = 'Advisory — See notifications below';
    } else {
      title.textContent = 'All Systems Operational';
    }
  }

  function updateStatusTime() {
    const el = document.getElementById('status-time');
    if (el) {
      const now = new Date();
      el.textContent = `Last checked: ${now.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })} at ${now.toLocaleTimeString('en-NZ', { hour: '2-digit', minute: '2-digit' })}`;
    }
  }

  function renderStaffBar() {
    const bar = document.getElementById('staff-bar');
    const greeting = document.getElementById('staff-greeting');
    if (!bar) return;
    bar.hidden = !isLoggedIn;
    if (isLoggedIn && greeting) {
      greeting.innerHTML = `Logged in as <strong>${esc(currentUser)}</strong>`;
    }
  }

  function sortedNotifications() {
    const priority = { outage: 0, warning: 1, info: 2, resolved: 3 };
    return [...notifications].sort((a, b) => {
      const pa = priority[a.status] ?? 4;
      const pb = priority[b.status] ?? 4;
      if (pa !== pb) return pa - pb;
      return new Date(b.created_at) - new Date(a.created_at);
    });
  }

  function renderList() {
    const container = document.getElementById('notifications-list');
    if (!container) return;

    if (notifications.length === 0) {
      container.innerHTML = `
        <div class="notif-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:#0ea5e9;opacity:0.4;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p>No active notifications — everything is running smoothly.</p>
        </div>`;
      return;
    }

    const sorted = sortedNotifications();
    const active   = sorted.filter(n => n.status !== 'resolved');
    const resolved = sorted.filter(n => n.status === 'resolved').slice(0, resolvedVisible);
    const slice = [...active, ...resolved];

    const hasActive   = notifications.some(n => n.status !== 'resolved');
    const hasResolved = notifications.some(n => n.status === 'resolved');
    const showHeaders = hasActive && hasResolved;

    let html = '';
    let inResolved = false;

    slice.forEach(n => {
      const isResolved = n.status === 'resolved';

      if (showHeaders) {
        if (!inResolved && !isResolved && html === '') {
          const activeCount = notifications.filter(n => n.status !== 'resolved').length;
          const worstStatus = notifications.some(n => n.status === 'outage') ? 'active-header' : 'warning-header';
          html += `<div class="section-header ${worstStatus}"><span>Active Issues</span><span class="section-badge">${activeCount}</span></div>`;
        }
        if (!inResolved && isResolved) {
          inResolved = true;
          html += `<div class="section-header resolved-header"><span>Past Notifications</span></div>`;
        }
      }

      html += renderCard(n);
    });

    container.innerHTML = html;
  }

  function renderCard(n) {
    const badgeClass = `badge-${n.status}`;
    const cardClass  = `notif-card status-${n.status}`;
    const edited = wasEdited(n.created_at, n.updated_at)
      ? ` <span class="edited">(edited ${fmt(n.updated_at)})</span>` : '';

    const resolveBtn = (isLoggedIn && n.status !== 'resolved')
      ? `<button class="action-btn resolve" data-action="resolve" data-id="${esc(n.id)}">✓ Mark Resolved</button>`
      : '';
    const staffActions = isLoggedIn ? `
      <div class="notif-staff-actions">
        ${resolveBtn}
        <span class="spacer"></span>
        <button class="action-btn edit"   data-action="edit-notif"   data-id="${esc(n.id)}">Edit</button>
        <button class="action-btn danger" data-action="delete-notif" data-id="${esc(n.id)}">Delete</button>
      </div>` : '';

    const commentsHtml = renderComments(n);

    return `
      <article class="${cardClass}" id="card-${n.id}">
        <div class="notif-header">
          <span class="notif-badge ${badgeClass}">${n.status}</span>
          <div class="notif-title-wrap">
            <div class="notif-title">${esc(n.title)}</div>
            <div class="notif-meta">${esc(n.author)} &mdash; ${fmt(n.created_at)}${edited}</div>
          </div>
          <a href="#card-${esc(n.id)}" class="notif-share-btn" data-action="share" data-id="${esc(n.id)}" title="Copy link to this notification" aria-label="Copy direct link to this notification">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </a>
        </div>
        <div class="notif-body">${escLines(n.body)}</div>
        ${staffActions}
        ${commentsHtml}
      </article>`;
  }

  function renderComments(n) {
    const hasComments = n.comments && n.comments.length > 0;
    if (!hasComments && !isLoggedIn) return '';

    const commentItems = (n.comments || []).map(c => renderComment(n.id, c)).join('');

    const addForm = isLoggedIn ? `
      <div class="add-comment-form">
        <span class="add-comment-label">Add Staff Update</span>
        <textarea id="comment-input-${esc(n.id)}" rows="3" placeholder="Add an update, workaround, or resolution note…"></textarea>
        <div class="add-comment-actions">
          <button class="action-btn primary" data-action="submit-comment" data-id="${esc(n.id)}">Post Update</button>
        </div>
      </div>` : '';

    return `
      <div class="comments-section">
        ${hasComments ? `<div class="comments-heading">${n.comments.length} comment${n.comments.length !== 1 ? 's' : ''}</div>` : ''}
        <div id="comments-list-${n.id}">${commentItems}</div>
        ${addForm}
      </div>`;
  }

  function renderComment(notifId, c) {
    const edited = wasEdited(c.created_at, c.updated_at)
      ? ` <span class="edited">(edited)</span>` : '';

    const actions = isLoggedIn ? `
      <div class="comment-actions">
        <button class="action-btn" data-action="edit-comment"   data-id="${esc(notifId)}" data-id2="${esc(c.id)}">Edit</button>
        <button class="action-btn danger" data-action="delete-comment" data-id="${esc(notifId)}" data-id2="${esc(c.id)}">Delete</button>
      </div>` : '';

    return `
      <div class="comment" id="comment-${c.id}">
        <div class="comment-meta"><strong>${esc(c.author)}</strong> &mdash; ${fmt(c.created_at)}${edited}</div>
        <div class="comment-body" id="cbody-${c.id}">${escLines(c.body)}</div>
        ${actions}
      </div>`;
  }

  // ── Infinite scroll (resolved items only) ───────────────────────────────────

  function updateSentinel() {
    const sentinel = document.getElementById('load-more-sentinel');
    if (!sentinel) return;
    const totalResolved = notifications.filter(n => n.status === 'resolved').length;
    const hasMore = resolvedVisible < totalResolved;
    sentinel.innerHTML = hasMore
      ? `<div class="load-more-spinner"><span></span></div>`
      : '';
  }

  function setupIntersectionObserver() {
    const sentinel = document.getElementById('load-more-sentinel');
    if (!sentinel) return;
    const observer = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return;
      const totalResolved = notifications.filter(n => n.status === 'resolved').length;
      if (resolvedVisible < totalResolved) {
        resolvedVisible += RESOLVED_PER_LOAD;
        renderList();
        updateSentinel();
      }
    }, { rootMargin: '200px' });
    observer.observe(sentinel);
  }

  // ── Notification CRUD ────────────────────────────────────────────────────────

  function showNotifForm(heading, id, status, title, body) {
    editingNotifId = id || null;
    document.getElementById('notif-form-heading').textContent = heading;
    document.getElementById('notif-id-input').value     = id || '';
    document.getElementById('notif-status-input').value  = status || 'info';
    document.getElementById('notif-title-input').value   = title || '';
    document.getElementById('notif-body-input').value    = body || '';
    const wrap = document.getElementById('notif-form-wrap');
    wrap.hidden = false;
    wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
    document.getElementById('notif-title-input').focus();
    hideFormError('notif-form-error');
  }

  function hideNotifForm() {
    document.getElementById('notif-form-wrap').hidden = true;
    editingNotifId = null;
  }

  function startEditNotif(id) {
    const n = notifications.find(n => n.id === id);
    if (!n) return;
    showNotifForm('Edit Notification', n.id, n.status, n.title, n.body);
  }

  async function submitNotifForm(e) {
    e.preventDefault();
    const id     = document.getElementById('notif-id-input').value;
    const status = document.getElementById('notif-status-input').value;
    const title  = document.getElementById('notif-title-input').value.trim();
    const body   = document.getElementById('notif-body-input').value.trim();
    if (!title || !body) return;

    const btn = document.getElementById('notif-save-btn');
    btn.disabled = true; btn.textContent = 'Saving…';

    try {
      let result;
      if (id) {
        result = await apiCall('update', { id }, { title, body, status });
      } else {
        result = await apiCall('create', {}, { title, body, status });
      }

      if (result.error) {
        showFormError('notif-form-error', result.error);
        return;
      }

      if (id) {
        const idx = notifications.findIndex(n => n.id === id);
        if (idx >= 0) notifications[idx] = result.notification;
      } else {
        notifications.unshift(result.notification);
      }

      hideNotifForm();
      render();
    } finally {
      btn.disabled = false; btn.textContent = 'Save Notification';
    }
  }

  async function resolveNotif(id) {
    const n = notifications.find(n => n.id === id);
    if (!n) return;
    const result = await apiCall('update', { id }, { title: n.title, body: n.body, status: 'resolved' });
    if (result.error) { alert(result.error); return; }
    const idx = notifications.findIndex(n => n.id === id);
    if (idx >= 0) notifications[idx] = result.notification;
    render();
  }

  async function deleteNotif(id) {
    const n = notifications.find(n => n.id === id);
    if (!n) return;
    if (!confirm(`Delete notification:\n"${n.title}"\n\nThis cannot be undone.`)) return;

    const result = await apiCall('delete', { id }, {});
    if (result.error) { alert(result.error); return; }

    notifications = notifications.filter(n => n.id !== id);
    render();
  }

  // ── Comment CRUD ─────────────────────────────────────────────────────────────

  async function submitComment(notifId) {
    const ta = document.getElementById(`comment-input-${notifId}`);
    const body = ta?.value.trim();
    if (!body) return;

    const result = await apiCall('comment_add', { id: notifId }, { body });
    if (result.error) { alert(result.error); return; }

    const n = notifications.find(n => n.id === notifId);
    if (n) n.comments.push(result.comment);
    render();
  }

  function startEditComment(notifId, commentId) {
    const n = notifications.find(n => n.id === notifId);
    const c = n?.comments.find(c => c.id === commentId);
    if (!c) return;

    const bodyEl = document.getElementById(`cbody-${commentId}`);
    if (!bodyEl) return;

    bodyEl.innerHTML = `
      <div class="comment-edit-wrap">
        <textarea class="comment-edit-textarea" id="cedit-${esc(commentId)}" rows="4">${esc(c.body)}</textarea>
        <div class="comment-edit-actions">
          <button class="action-btn save"       data-action="save-edit-comment"   data-id="${esc(notifId)}" data-id2="${esc(commentId)}">Save</button>
          <button class="action-btn cancel-btn" data-action="cancel-edit-comment">Cancel</button>
        </div>
      </div>`;
    document.getElementById(`cedit-${commentId}`)?.focus();
  }

  async function saveEditComment(notifId, commentId) {
    const ta = document.getElementById(`cedit-${commentId}`);
    const body = ta?.value.trim();
    if (!body) return;

    const result = await apiCall('comment_update', { id: notifId, comment_id: commentId }, { body });
    if (result.error) { alert(result.error); return; }

    const n = notifications.find(n => n.id === notifId);
    if (n) {
      const idx = n.comments.findIndex(c => c.id === commentId);
      if (idx >= 0) n.comments[idx] = result.comment;
    }
    render();
  }

  function cancelEditComment() {
    render();
  }

  async function deleteComment(notifId, commentId) {
    if (!confirm('Delete this comment?')) return;

    const result = await apiCall('comment_delete', { id: notifId, comment_id: commentId }, {});
    if (result.error) { alert(result.error); return; }

    const n = notifications.find(n => n.id === notifId);
    if (n) n.comments = n.comments.filter(c => c.id !== commentId);
    render();
  }

  // ── Share ────────────────────────────────────────────────────────────────────

  function shareNotif(id, btn) {
    const url = `${location.origin}/notifications.html#card-${id}`;
    navigator.clipboard?.writeText(url).then(() => {
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 2000);
    });
  }

  // ── Auth ─────────────────────────────────────────────────────────────────────

  async function submitLogin(e) {
    e.preventDefault();
    const username = document.getElementById('login-username').value.trim();
    const password = document.getElementById('login-password').value;
    hideFormError('login-error');

    const btn = e.target.querySelector('[type=submit]');
    btn.disabled = true; btn.textContent = 'Logging in…';

    try {
      const result = await apiCall('login', {}, { username, password });
      if (result.error) {
        showFormError('login-error', result.error);
        return;
      }
      isLoggedIn = true;
      currentUser = result.user;
      csrfToken = result.csrf ?? '';
      document.getElementById('login-panel').hidden = true;
      document.getElementById('login-password').value = '';
      render();
    } catch (err) {
      showFormError('login-error', 'Connection error — check the server is reachable.');
    } finally {
      btn.disabled = false; btn.textContent = 'Login';
    }
  }

  async function logout() {
    await apiCall('logout', {}, {});
    isLoggedIn = false;
    currentUser = null;
    csrfToken = '';
    hideNotifForm();
    render();
  }

  // ── Form helpers ─────────────────────────────────────────────────────────────

  function showFormError(id, msg) {
    const el = document.getElementById(id);
    if (el) { el.textContent = msg; el.hidden = false; }
  }

  function hideFormError(id) {
    const el = document.getElementById(id);
    if (el) { el.hidden = true; el.textContent = ''; }
  }

  // ── Wire up events ───────────────────────────────────────────────────────────
  // Note: Astro injects this module after </html>, so DOMContentLoaded has
  // already fired. Run setup directly instead of waiting for that event.

  function scrollToHash() {
    const hash = location.hash;
    if (!hash.startsWith('#card-')) return;
    const el = document.getElementById(hash.slice(1));
    if (!el) return;
    setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'center' }), 80);
    el.classList.add('card-highlighted');
    setTimeout(() => el.classList.remove('card-highlighted'), 3000);
  }

  init().then(() => { setupIntersectionObserver(); scrollToHash(); });

  document.getElementById('notif-form')
    ?.addEventListener('submit', submitNotifForm);

  document.getElementById('notif-cancel-btn')
    ?.addEventListener('click', hideNotifForm);

  document.getElementById('add-notif-btn')
    ?.addEventListener('click', () => showNotifForm('New Notification', '', 'info', '', ''));

  document.getElementById('logout-btn')
    ?.addEventListener('click', logout);

  document.getElementById('login-form')
    ?.addEventListener('submit', submitLogin);

  document.getElementById('login-toggle')
    ?.addEventListener('click', () => {
      const panel = document.getElementById('login-panel');
      panel.hidden = !panel.hidden;
      if (!panel.hidden) document.getElementById('login-username').focus();
    });

  document.getElementById('login-cancel')
    ?.addEventListener('click', () => {
      document.getElementById('login-panel').hidden = true;
    });

  // ── Event delegation (handles buttons in dynamically rendered cards) ─────────

  document.getElementById('notifications-list')
    ?.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!btn) return;
      const action = btn.dataset.action!;
      const id     = btn.dataset.id  ?? '';
      const id2    = btn.dataset.id2 ?? '';
      switch (action) {
        case 'share':               e.preventDefault(); shareNotif(id, btn); break;
        case 'resolve':             resolveNotif(id);              break;
        case 'edit-notif':          startEditNotif(id);            break;
        case 'delete-notif':        deleteNotif(id);               break;
        case 'submit-comment':      submitComment(id);             break;
        case 'edit-comment':        startEditComment(id, id2);     break;
        case 'delete-comment':      deleteComment(id, id2);        break;
        case 'save-edit-comment':   saveEditComment(id, id2);      break;
        case 'cancel-edit-comment': cancelEditComment();           break;
      }
    });
</script>
</Layout>

