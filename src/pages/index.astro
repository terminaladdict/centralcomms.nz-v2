        <h2 class="section-title">Trusted Across the Waikato</h2>
      </div>

      <div class="testimonials-grid">
        {testimonials.map((t, i) => {
          const base = t.img.replace(/\.(jpg|jpeg|png)$/, '');
          const webp1x = `${base}-160.webp`;
          const webp2x = `${base}-320.webp`;
          return (
          <div class={`testimonial-card reveal reveal-delay-${(i % 3) + 1}`}>
