                  <source srcset={`${webp1x} 1x, ${webp2x} 2x`} type="image/webp" />
                  <img
                    src={t.img}
                    alt={t.name}
                    width="44"
                    height="44"
                    loading="lazy"
                    class="testimonial-avatar"
                  />
                </picture>
                <picture>
                  <source srcset={`${webp1x} 1x, ${webp2x} 2x`} type="image/webp" />
                  <img
                    src={t.img}
                    alt=""
                    aria-hidden="true"
                    class="testimonial-avatar-zoom"
                    width="160"
                    height="160"
                    loading="lazy"
                  />
                </picture>
              </div>
              <div>
                <div class="testimonial-name">{t.name}</div>
                <div class="testimonial-company">{t.company}</div>
