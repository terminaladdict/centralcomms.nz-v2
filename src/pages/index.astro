      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CONTACT CTA -->
  <section class="cta-section section-alt" id="contact">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-text">
          <span class="section-tag reveal">Ready to talk?</span>
          <h2 class="section-title reveal reveal-delay-1">Let's Build Your<br />Business Infrastructure</h2>
          <p class="about-p reveal reveal-delay-2">
            Whether you need a new phone system, CCTV installation, network upgrade, or reliable
            internet — we'd love to hear from you. Call us on <a href="tel:+6480084800038" style="color:#0284c7;font-weight:600;">0800 848 0038</a>
            or fill in the form and we'll get back to you promptly.
          </p>
        </div>
        <div class="contact-form reveal reveal-delay-2">
          <form id="contact-form" method="post" action="/assets/php/contact.php" novalidate>
            <div class="form-row">
              <div class="form-field">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" required autocomplete="name" placeholder="Your name" />
                <span class="field-error" aria-live="polite"></span>
              </div>
              <div class="form-field">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@company.co.nz" />
                <span class="field-error" aria-live="polite"></span>
              </div>
            </div>
            <div class="form-field">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="027 000 0000" />
            </div>
            <div class="form-field">
              <label for="message">Message *</label>
              <textarea id="message" name="message" required placeholder="Tell us what you need…"></textarea>
            </div>
            <div id="form-status" aria-live="polite"></div>
            <button type="submit" class="btn btn-ember" style="width:100%;justify-content:center;">
              Send Message
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
  const canvas = document.getElementById('network-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  interface Node {
    x: number; y: number;
    vx: number; vy: number;
    r: number; opacity: number;
  }

  let nodes: Node[] = [];
  const COUNT = 55;
  const DIST = 160;

  function resize() {
    canvas.width  = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }

  function init() {
    resize();
    nodes = Array.from({ length: COUNT }, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      vx: (Math.random() - 0.5) * 0.35,
      vy: (Math.random() - 0.5) * 0.35,
      r: Math.random() * 1.8 + 0.8,
      opacity: Math.random() * 0.4 + 0.2,
    }));
  }

  function frame() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const d  = Math.hypot(dx, dy);
        if (d < DIST) {
          const alpha = (1 - d / DIST) * 0.25;
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.strokeStyle = `rgba(14,165,233,${alpha})`;
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }
    }

    nodes.forEach((n) => {
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(14,165,233,${n.opacity})`;
      ctx.fill();
    });

    nodes.forEach((n) => {
      n.x += n.vx;
      n.y += n.vy;
      if (n.x < 0 || n.x > canvas.width)  n.vx *= -1;
      if (n.y < 0 || n.y > canvas.height) n.vy *= -1;
    });

    requestAnimationFrame(frame);
  }

  window.addEventListener('resize', () => { resize(); }, { passive: true });
  init();
  frame();
  </script>

  <script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const submitBtn = form?.querySelector('[type="submit"]') as HTMLButtonElement;

  function validateForm(): boolean {
    let valid = true;
    form.querySelectorAll('.field-error').forEach(el => (el.textContent = ''));
    form.querySelectorAll('.form-field').forEach(el => el.classList.remove('has-error'));

    const nameEl  = form.querySelector('[name="name"]')  as HTMLInputElement;
    const emailEl = form.querySelector('[name="email"]') as HTMLInputElement;

    if (nameEl.value.trim().length < 2) {
      nameEl.closest('.form-field')!.classList.add('has-error');
      nameEl.closest('.form-field')!.querySelector('.field-error')!.textContent = 'Please enter your name (at least 2 characters).';
      valid = false;
    }

    const emailVal = emailEl.value.trim();
    if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      emailEl.closest('.form-field')!.classList.add('has-error');
      emailEl.closest('.form-field')!.querySelector('.field-error')!.textContent = 'Please enter a valid email address.';
      valid = false;
    }

    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateForm()) return;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    status.className = '';
    status.textContent = '';

    try {
      const data = new FormData(form);
      const res  = await fetch('/assets/php/contact.php', { method: 'POST', body: data });
      const json = await res.json();

      if (json.success) {
        status.className = 'success';
        status.textContent = json.message || 'Message sent! We\'ll be in touch shortly.';
        form.reset();
      } else {
        throw new Error(json.message || 'Unknown error');
      }
    } catch (err: any) {
      status.className = 'error';
      status.textContent = err.message || 'Sorry, something went wrong. Please call us on 0800 848 0038.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
  </script>

</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #030b18;
  }

  #network-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    max-width: 820px;
  }

  .hero-heading {
    font-size: clamp(2rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #f0f6ff;
    margin: 0 0 1.5rem;
  }
  .hero-heading em {
    font-style: normal;
    color: #38bdf8;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #93c5d8;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
