---
const services = [
  { href: '/voip.html',                 label: 'VoIP Phone Systems' },
  { href: '/cctv.html',                 label: 'CCTV & Surveillance' },
  { href: '/networking--data.html',     label: 'Networking & Data' },
  { href: '/it-support.html',           label: 'IT Support' },
  { href: '/wireless.html',             label: 'Managed Wireless' },
  { href: '/ultra-fast-broadband.html', label: 'Ultra Fast Broadband' },
  { href: '/websites-and-hosting.html', label: 'Websites & Hosting' },
];
---

<footer>
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand col -->
      <div class="footer-col">
        <img
          src="/assets/images/centralcomms.svg"
          alt="Central Communications Ltd"
          class="footer-logo"
          width="220"
          height="49"
        />
        <p class="footer-tagline">Building better business infrastructure since 1989.</p>
        <div class="footer-contact">
          <a href="tel:+6480084800038" class="footer-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.59 4.87 2 2 0 0 1 3.56 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.16a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            0800 848 0038
          </a>
          <a href="mailto:info@centralcomms.nz" class="footer-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            info@centralcomms.nz
          </a>
        </div>
      </div>

      <!-- Services col -->
      <div class="footer-col">
        <h3 class="footer-heading">Services</h3>
        <ul class="footer-links">
          {services.map(s => (
            <li><a href={s.href} class="footer-link">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Address col -->
      <div class="footer-col">
        <h3 class="footer-heading">Address</h3>
        <address class="footer-address">
          Unit 3/103C Greenwood Street<br />
          Frankton, Hamilton 3204<br />
          <br />
          P.O. Box 221<br />
          Waikato Mail Centre<br />
          Hamilton 3240
        </address>
        <p class="footer-coverage">
          Serving Hamilton, Waikato,<br />
          Bay of Plenty & South Auckland
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; <span id="footer-year"></span> Central Communications Ltd
      </p>
      <div class="footer-legal">
        <a href="/fair-use.html">Fair Use Policy</a>
        <a href="/privacypolicy.html">Privacy Policy</a>
        <a href="/terms.html">Terms &amp; Conditions</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid rgba(14, 165, 233, 0.1);
    background: #071525;
    padding: 4rem 0 2rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    width: 220px;
    height: auto;
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    color: #7ea3c8;
    font-size: 0.875rem;
    margin-top: 0.75rem;
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: #7ea3c8;
    transition: color 0.2s;
  }
  .footer-contact-item:hover { color: #0ea5e9; }
  .footer-contact-item svg { color: #0ea5e9; flex-shrink: 0; }

  .footer-heading {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0ea5e9;
    margin-bottom: 1rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: #7ea3c8;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #e8f1ff; }

  .footer-address {
    font-style: normal;
    font-size: 0.875rem;
    color: #7ea3c8;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .footer-coverage {
    font-size: 0.75rem;
    color: #7ea3c8;
    line-height: 1.6;
  }

  .footer-bottom {
    border-top: 1px solid rgba(14, 165, 233, 0.08);
    padding-top: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: #7ea3c8;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-legal a {
    font-size: 0.8rem;
    color: #7ea3c8;
    transition: color 0.2s;
  }
  .footer-legal a:hover { color: #e8f1ff; }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
